   "source": [
    "import itertools\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "def grid_search(modele, train, test, p_grid, score_opt=\"RMSE\", figsize=(15,8), val=False, X_train=False, X_test=False, verbose=0, epochs=80):\n",
    "    \"\"\"\n",
    "    grid_search simplifié et autonome pour un modèle LSTM ou similaire.\n",
    "    \n",
    "    Args:\n",
    "        modele: fonction de modélisation acceptant train, val, test + params via **kwargs.\n",
    "        train, test: séries temporelles.\n",
    "        p_grid: dictionnaire hyperparamètres à tester.\n",
    "        score_opt: metric pour choisir le meilleur modèle.\n",
    "        figsize: taille figure heatmap.\n",
    "        val: split de validation (optionnel).\n",
    "        X_train, X_test: covariables (optionnel).\n",
    "\n",
    "    Plot:\n",
    "        La grille des scores_opt des deux premiers paramètres donnés.\n",
    "        \n",
    "    Returns:\n",
    "        df_scores: DataFrame avec toutes les combinaisons et scores.\n",
    "    \"\"\"\n",
    "    \n",
    "    # toutes les combinaisons possibles de paramètres\n",
    "    keys = list(p_grid.keys())\n",
    "    combinations = list(itertools.product(*p_grid.values()))\n",
    "    \n",
    "    resultats = []\n",
    "    \n",
    "    for combo in combinations:\n",
    "        params = dict(zip(keys, combo))\n",
    "        \n",
    "        # appelle le modèle en passant tous les params en **kwargs\n",
    "        if type(val) != bool:\n",
    "            if type(X_test) != bool: # avec covariables\n",
    "                resultat = modele(train=train, val=val, test=test, X_train=X_train, X_test=X_test, verbose=verbose, epochs=80, **params)\n",
    "            else:\n",
    "                resultat = modele(train=train, val=val, test=test, verbose=verbose, epochs=80, **params)\n",
    "        else:\n",
    "            if type(X_test) != bool: # avec covariables\n",
    "                resultat = modele(train=train, test=test, X_train=X_train, X_test=X_test, verbose=verbose, epochs=80, **params)\n",
    "            else:\n",
    "                resultat = modele(train=train, test=test, verbose=verbose, epochs=80, **params)\n",
    "        \n",
    "        # récupération des scores\n",
    "        rmse = resultat.get('rmse', np.nan)\n",
    "        mae  = resultat.get('mae', np.nan)\n",
    "        \n",
    "        # on stocke tous les params + scores\n",
    "        resultats.append({**params, \"RMSE\": rmse, \"MAE\": mae})\n",
    "    \n",
    "    # DataFrame finale\n",
    "    df_scores = pd.DataFrame(resultats)\n",
    "    \n",
    "    # meilleurs paramètres\n",
    "    best = df_scores.loc[df_scores[score_opt].idxmin()]\n",
    "    print(f\"\\nMeilleurs paramètres selon {score_opt} :\\n{best}\")\n",
    "    print(f\"Meilleur score ({score_opt}) : {best[score_opt]}\")\n",
    "    \n",
    "    # =========================\n",
    "    # VISUALISATION GRILLE\n",
    "    # =========================\n",
    "    if len(keys) >= 2:\n",
    "        # récupérer les noms exacts des paramètres pour l'axe\n",
    "        param_x = list(p_grid.keys())[0]\n",
    "        param_y = list(p_grid.keys())[1]\n",
    "        \n",
    "        # résoudre les doublons en moyennant les scores\n",
    "        df_plot = df_scores.groupby([param_y, param_x], as_index=False).agg({score_opt: 'mean'})\n",
    "        \n",
    "        # pivot pour visualisation\n",
    "        pivot = df_plot.pivot(index=param_y, columns=param_x, values=score_opt)\n",
    "        \n",
    "        # visualisation\n",
    "        plt.figure(figsize=figsize)\n",
    "        plt.imshow(pivot, cmap=\"copper\")\n",
    "        plt.colorbar()\n",
    "        plt.xticks(np.arange(len(pivot.columns)), pivot.columns)\n",
    "        plt.yticks(np.arange(len(pivot.index)), pivot.index)\n",
    "        plt.xlabel(param_x)  # ou labels_grille[0] si tu veux un label humain lisible\n",
    "        plt.ylabel(param_y)  # ou labels_grille[1]\n",
    "        plt.title(f\"Grid search ({score_opt})\")\n",
    "        plt.show()\n",
    "    \n",
    "    return df_scores"
   ]
  },
